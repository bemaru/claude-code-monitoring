{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "count(count_over_time(claude_code_session_count_total{job=\"otel-collector\"}[1h])) or vector(0)", "legendFormat": "Sessions" }
      ],
      "title": "Sessions (1h)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(max_over_time(claude_code_cost_usage_USD_total{job=\"otel-collector\"}[1h])) or vector(0)", "legendFormat": "Cost" }
      ],
      "title": "Cost (1h)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 50000 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(max_over_time(claude_code_token_usage_tokens_total{job=\"otel-collector\"}[1h])) or vector(0)", "legendFormat": "Tokens" }
      ],
      "title": "Tokens (1h)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(max_over_time(claude_code_lines_of_code_count_total{job=\"otel-collector\"}[1h])) or vector(0)", "legendFormat": "LoC" }
      ],
      "title": "Lines of Code (1h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Cost & Token Analysis",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum", "mean"] } },
      "targets": [
        { "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total{job=\"otel-collector\"}[1h]))", "legendFormat": "{{model}}" }
      ],
      "title": "Cost by Model (Hourly)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "scaleDistribution": { "type": "log", "log": 2 } } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"] } },
      "targets": [
        { "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{job=\"otel-collector\"}[5m]) * 60)", "legendFormat": "{{type}}" }
      ],
      "title": "Token Usage Rate by Type",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Tool Usage",
      "type": "row"
    },
    {
      "datasource": "Loki",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.tool_result\" [5m]))",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "title": "Tool Usage Rate (per 5min)",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 9,
      "targets": [
        {
          "expr": "100 * (sum by (tool_name) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.tool_result\" | success=\"true\" [15m]))) / (sum by (tool_name) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.tool_result\" [15m])))",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "title": "Tool Success Rate (%)",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.tool_result\" [$__range]))",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "title": "Cumulative Tool Usage",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Performance & Errors",
      "type": "row"
    },
    {
      "datasource": "Loki",
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "avg by (model) (avg_over_time({service_name=\"claude-code\"} |= \"claude_code.api_request\" | unwrap duration_ms [$__interval]))",
          "legendFormat": "{{model}}"
        }
      ],
      "title": "API Request Duration by Model",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "stacking": { "mode": "normal" }, "drawStyle": "bars" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 12,
      "targets": [
        {
          "expr": "sum by (status_code) (count_over_time({service_name=\"claude-code\"} |= \"claude_code.api_error\" [5m]))",
          "legendFormat": "HTTP {{status_code}}"
        }
      ],
      "title": "API Errors by Status Code",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Productivity",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"] } },
      "targets": [
        { "expr": "sum by (type) (rate(claude_code_lines_of_code_count_total{job=\"otel-collector\"}[5m]) * 60)", "legendFormat": "{{type}}" }
      ],
      "title": "Code Changes Rate (lines/min)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 14,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"] } },
      "targets": [
        { "expr": "sum(increase(claude_code_active_time_seconds_total{job=\"otel-collector\"}[5m]))", "legendFormat": "Active Time" }
      ],
      "title": "Active Time (per 5min)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "id": 105,
      "title": "Event Logs",
      "type": "row"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 50 },
      "id": 15,
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} |= \"claude_code.tool_result\" | line_format \"[{{.tool_name}}] {{if eq .success \\\"true\\\"}}OK{{else}}FAIL{{end}} {{.duration_ms}}ms {{if .error}}ERROR: {{.error}}{{end}}\"",
          "legendFormat": ""
        }
      ],
      "title": "Tool Execution Events",
      "type": "logs"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 58 },
      "id": 16,
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} |= \"claude_code.api_error\" | line_format \"[{{.model}}] HTTP {{.status_code}} {{.duration_ms}}ms ERROR: {{.error}}\"",
          "legendFormat": ""
        }
      ],
      "title": "API Error Events",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["claude-code", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Code Observability",
  "uid": "claude-code-obs"
}
